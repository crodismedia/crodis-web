# Configuración de OpenAI para Desarrollo Local
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ⚠️ IMPORTANTE:
# 1. Copia este archivo a .env.local (NO lo commits a Git)
# 2. Reemplaza la API key con tu clave de OpenAI
# 3. Obtén tu clave en: https://platform.openai.com/api-keys
